@using Microsoft.AspNetCore.Identity

<link rel="stylesheet" href="site.css">

@{
    ViewData["title"]= "Valid Users";
}

<h1>@ViewData["title"]</h1>






<table>
    <tr>
        <th>Usernames  </th>
        <th>Passwords  </th>
        <th>Is Admin?</th>
    </tr>
    <tr>
        <td>Vinnie Gar</td>
        <td>PickleMe</td>
        <td>The bigest admin in town</td>
    </tr>

    <tr>
        <td>Rousseau(cat)</td>
        <td>Why would a cat have a password?</td>
        <td>The cat is an admin though</td>
    </tr>
    @foreach(var uname in Model){
        <tr>
            <td>
                @uname.Name
            </td>
            <td>
                @uname.Password
            </td>
            <td>
                @uname.IsAdmin
            </td>
        </tr>

    }

    
    <tr>
        <td>
            
        </td>
    </tr>
</table>

