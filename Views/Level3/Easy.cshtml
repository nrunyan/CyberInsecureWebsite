@{
    ViewData["Title"] = "Easy";
}
<h1>Time Travler's Movie Review</h1>
<br />
<p>
    Execute a simple SQL injection. This time traveler accidentally included a table 
    entitled "unreleased" which includes a movie from the future which hasn't been released
    yet, but which he has already reviewed. Find the "name" field (out of the 4 total fields) and submit it as the flag.
</p>

<br />
<br />
<h2>Movie Search</h2>

<form method="post">
    <input type="text" name="search" value="@ViewBag.Search" />
    <button type="submit">Search</button>
</form>

@if (ViewBag.Results != null)
{
    <ul>
        @foreach (var row in ViewBag.Results)
        {
            <li>@row</li>
        }
    </ul>
}
<br />
<br />
<div style="margin-top: 2rem;">
    <h2>Submit Flag</h2>
    <form method="post" asp-action="EasyFlag">
        <input type="text" name="flag" placeholder="Secret Movie" />
        <button type="submit">Submit</button>
    </form>
    @if (ViewBag.FlagError != null)
    {
        <p>@ViewBag.FlagError</p>
    }
</div>
<br />
<br />
<br />
<br />
<a href="https://owasp.org/www-community/attacks/SQL_Injection">SQL Injection Help</a>
