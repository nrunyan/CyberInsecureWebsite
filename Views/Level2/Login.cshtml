@model InsecureWebsite.Models.Username
@{
    ViewData["Title"] = "Login";
}

<div class="text-center">
    <h1>Level 2 — Login</h1>
    <p>Please Login.</p>
    <p><strong>DON'T PUT IN ACTUAL PASSWORDS PLEASE</strong></p>
</div>
<p>To beat this level, Please login as user: <b>Vinnie Gar</b></p>
<form asp-controller="Level2" asp-action="Login" method="post">
    <p>
        <label asp-for="Name">Username:</label>
        <input asp-for="Name" />
    </p>
    <p>
        <label asp-for="Password">Password:</label>
        <input asp-for="Password" />
    </p>
    <button type="submit">Login</button>
</form>
@*redirects to the change password page*@


<details>
    <summary>Hint 1</summary>
    <p>What happens when you log in?</p>
</details>